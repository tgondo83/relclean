# ── Development ──────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:8080
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
JWT_SECRET=your_local_dev_secret_here

# ── Production (set these in Render / hosting dashboard) ──
# PORT=10000                         (Render sets this automatically)
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://...       (your Atlas connection string)
# JWT_SECRET=<strong-random-secret>   (min 32 chars)
# FRONTEND_URL=https://your-app.onrender.com
#
# If deploying frontend separately on Vercel, comma-separate the origins:
# FRONTEND_URL=https://your-backend.onrender.com,https://your-app.vercel.app
